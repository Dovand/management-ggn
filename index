        async function pendingTicket(docId) {
    const ticket = tickets.find(t => t.id === docId);
    if(!ticket) return;
    
    if(ticket.status === 'pending') {
        const note = prompt('Keterangan resume (opsional):');
        try {
            await db.collection('tickets').doc(docId).update({
                status: 'open',
                pendingNote: note || 'Diresume dari pending',
                pendingAt: null
            });
            notif('Tiket '+ticket.ticketId+' dilanjutkan','info');
            startTimer();
        } catch(e) { notif('Gagal resume','danger'); }
        return;
    }
    
    const note = prompt('Keterangan pending:');
    if(note === null) return;
    try {
        await db.collection('tickets').doc(docId).update({
            status: 'pending',
            pendingNote: note || 'Tidak ada keterangan',
            pendingAt: firebase.firestore.Timestamp.fromDate(new Date())
        });
        notif('Tiket '+ticket.ticketId+' di-pending','warning');
        const hasOpen = tickets.some(t => t.id !== docId && t.status === 'open');
        if(!hasOpen) stopTimer();
    } catch(e) { notif('Gagal pending','danger'); }
}

        async function closeTicket(docId) {
    const ticket = tickets.find(t => t.id === docId);
    if(!ticket) return;
    
    const now = new Date();
    const createdAt = ticket.createdAt.toDate();
    const diffMs = now.getTime() - createdAt.getTime();
    const ttr = diffMs / 60000;
    const isOverdue = ttr > ticket.duration;
    
    let keterangan = '';
    
    if(isOverdue) {
        // ===== MINTA INPUT MANUAL DARI TEKNISI =====
        const { value } = await Swal.fire({
            title: '⚠️ Tiket Overdue!',
            text: 'Tiket ini melebihi durasi. Berikan keterangan penyebab:',
            input: 'textarea',
            inputPlaceholder: 'Tulis keterangan overdue...',
            showCancelButton: true,
            confirmButtonText: 'Close Tiket',
            cancelButtonText: 'Batal',
            confirmButtonColor: '#dc2626',
            inputValidator: (value) => {
                if(!value) {
                    return 'Keterangan wajib diisi!';
                }
            }
        });
        
        if(!value) return; // Batal
        keterangan = '⚠️ OVERDUE: ' + value;
        
    } else {
        keterangan = '✅ Selesai tepat waktu (' + formatDur(ttr) + ')';
    }
    
    try {
        await db.collection('tickets').doc(docId).update({
            status: 'close',
            ttr: ttr,
            closedAt: firebase.firestore.Timestamp.fromDate(now),
            pendingNote: keterangan
        });
        
        notif('Tiket '+ticket.ticketId+' ditutup!', 'success');
        
        const hasOpen = tickets.some(t => t.id !== docId && t.status === 'open');
        if(!hasOpen) stopTimer();
    } catch(e) {
        notif('Gagal tutup tiket', 'danger');
    }
}
