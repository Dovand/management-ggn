                updateStats();
                if(document.getElementById('technicianSection').style.display !== 'none') renderPerformance();
                tickets.filter(t => t.status==='open' && t.ttr > t.duration).forEach(t => {
                    notif('🚨 Tiket '+t.ticketId+' - '+t.customer+' OVERDUE!','danger');
                });
            });
        }

        setupRealtime();
        document.getElementById('btnTambahTeknisi').addEventListener('click', addTechnician);
        notif('🚀 HelpDesk Pro siap!','info');

        // default: ticket section tampil
        document.getElementById('ticketSection').style.display = 'block';
        document.getElementById('technicianSection').style.display = 'none';
        document.querySelector('.sidebar .nav-item:first-child').classList.add('active');

        document.getElementById('btnTambahTeknisi').addEventListener('click', function(e) {
    // Tunggu sebentar setelah klik, lalu kosongkan
    setTimeout(function() {
        document.getElementById('techName').value = '';
        document.getElementById('techPhone').value = '';
    }, 100);
});

document.querySelector('#ticketId').value = document.querySelector('#customer').value = document.querySelector('#description').value = document.querySelector('#duration').value = '';
selectedTechs = [];
renderTechDropdown();
    </script>
</body>
