
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HelpDesk Pro · GGN</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #eef2f6;
            display: flex;
            min-height: 100vh;
            color: #0b1a33;
        }

        /* SIDEBAR */
        .sidebar {
            width: 240px;
            background: #0b1a33;
            color: #f0f4fe;
            padding: 28px 16px;
            display: flex;
            flex-direction: column;
            gap: 28px;
            height: 100vh;
            position: sticky;
            top: 0;
            overflow-y: auto;
            flex-shrink: 0;
            box-shadow: 2px 0 12px rgba(0,0,0,0.06);
        }
        .sidebar .brand { font-size: 20px; font-weight: 700; display:flex; align-items:center; gap:10px; color:white; }
        .sidebar .brand i { color:#3b82f6; }
        .sidebar .menu-label { font-size: 11px; text-transform: uppercase; letter-spacing:0.8px; color:#7b8ba3; margin-top:8px; }
        .sidebar .nav-item {
            display: flex; align-items: center; gap: 14px; padding: 12px 16px;
            border-radius: 12px; color: #cbd5e1; font-weight: 500; cursor: pointer;
            transition:0.2s;
        }
        .sidebar .nav-item:hover { background:#1e3557; color:white; }
        .sidebar .nav-item.active { background:#1e3a6b; color:white; box-shadow:0 2px 8px rgba(59,130,246,0.2); }
        .sidebar .nav-item i { width:20px; text-align:center; }

        .main {
            flex:1;
            padding: 24px 30px 40px;
            background: #f6f9fc;
            min-width:0;
        }

        /* top bar */
        .top-bar {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 28px; flex-wrap: wrap; gap:12px;
        }
        .top-bar h1 { font-size:26px; font-weight:700; color:#0b1a33; }
        .top-bar .live-badge {
            background:#dbeafe; color:#1e4b8f; padding:6px 18px; border-radius:30px;
            font-size:13px; font-weight:600; display:flex; align-items:center; gap:8px;
        }
        .top-bar .live-badge .dot { width:9px; height:9px; background:#22c55e; border-radius:50%; display:inline-block; animation: blink 1.2s infinite; }
        @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.3;} }

        /* stats */
        .stats-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(150px,1fr));
            gap:16px; margin-bottom:30px;
        }
        .stat-card {
            background:white; border-radius:18px; padding:18px 16px 14px;
            border:1px solid #e9edf3; box-shadow:0 2px 6px rgba(0,0,0,0.02);
            display:flex; align-items:center; justify-content:space-between; position:relative;
        }
        .stat-card .num { font-size:30px; font-weight:700; color:#0b1a33; line-height:1; }
        .stat-card .label { font-size:13px; font-weight:500; color:#5b6e89; margin-top:4px; }
        .stat-card .icon-circle {
            width:44px; height:44px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:20px;
        }
        .stat-card .icon-circle.blue { background:#dbeafe; color:#2563eb; }
        .stat-card .icon-circle.green { background:#d1fae5; color:#059669; }
        .stat-card .icon-circle.red { background:#fee2e2; color:#dc2626; }
        .stat-card .icon-circle.orange { background:#fed7aa; color:#c2410c; }

        .stat-card .btn-stat {
            position:absolute; bottom:6px; right:12px; font-size:11px;
            background:#f1f5f9; border:none; padding:2px 12px; border-radius:30px;
            color:#2c3e5a; font-weight:600; cursor:pointer; transition:0.2s;
        }
        .stat-card .btn-stat:hover { background:#e2e8f0; }

        .card {
            background:white; border-radius:18px; padding:20px 22px;
            border:1px solid #e9edf3; box-shadow:0 2px 8px rgba(0,0,0,0.02);
            margin-bottom:24px;
        }
        .card-title { font-size:17px; font-weight:700; margin-bottom:18px; display:flex; align-items:center; gap:8px; }

        .form-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(180px,1fr));
            gap:14px 16px;
        }
        .form-group { display:flex; flex-direction:column; gap:4px; }
        .form-group label { font-size:13px; font-weight:600; color:#2c3e5a; }
        .form-group input, .form-group textarea, .form-group select {
            padding:8px 12px; border:1px solid #d1d9e6; border-radius:10px;
            font-size:14px; background:white; transition:0.2s;
        }
        .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
            outline:none; border-color:#2563eb; box-shadow:0 0 0 3px rgba(37,99,235,0.08);
        }
        .form-group textarea { min-height:38px; resize:vertical; }

        .btn {
            padding:8px 22px; border:none; border-radius:10px; font-weight:600; font-size:14px;
            cursor:pointer; transition:0.15s; display:inline-flex; align-items:center; gap:6px;
        }
        .btn-primary { background:#2563eb; color:white; }
        .btn-primary:hover { background:#1d4ed8; }
        .btn-success { background:#16a34a; color:white; }
        .btn-success:hover { background:#15803d; }
        .btn-danger { background:#dc2626; color:white; }
        .btn-danger:hover { background:#b91c1c; }
        .btn-warning { background:#f59e0b; color:white; }
        .btn-warning:hover { background:#d97706; }
        .btn-sm { padding:3px 12px; font-size:12px; }
        .btn-outline { background:transparent; border:1px solid #cbd5e1; color:#1e293b; }
        .btn-outline:hover { background:#f1f5f9; }

        .table-wrap { overflow-x:auto; border-radius:14px; border:1px solid #e9edf3; }
        table { width:100%; border-collapse:collapse; font-size:14px; }
        table th {
            background:#f8fafc; padding:12px 12px; text-align:left; font-weight:600;
            color:#2c3e5a; border-bottom:2px solid #e2e8f0; white-space:nowrap;
            font-size:12px; text-transform:uppercase; letter-spacing:0.3px;
        }
        table td { padding:10px 12px; border-bottom:1px solid #f1f5f9; vertical-align:middle; }
        table tr:hover td { background:#fafcff; }

        .badge-status {
            display:inline-flex; align-items:center; gap:4px; padding:2px 14px;
            border-radius:30px; font-size:12px; font-weight:600;
        }
        .badge-status.open { background:#fef3c7; color:#92400e; }
        .badge-status.close { background:#dcfce7; color:#166534; }
        .badge-status.pending { background:#e0e7ff; color:#3730a3; }

        .tech-badge {
            background:#eef2ff; padding:1px 12px; border-radius:20px; font-size:12px;
            color:#1e3a6b; border:1px solid #c7d2fe; display:inline-block; margin:2px 3px;
        }

        .filter-bar {
            display:flex; flex-wrap:wrap; gap:10px 14px; background:#f8fafc;
            padding:12px 16px; border-radius:14px; margin-bottom:16px; align-items:center;
        }
        .filter-bar input, .filter-bar select {
            padding:6px 12px; border:1px solid #d1d9e6; border-radius:8px;
            font-size:13px; background:white; min-width:120px;
        }

        .empty { text-align:center; padding:30px 10px; color:#94a3b8; }
        .empty .icon { font-size:36px; display:block; margin-bottom:6px; }

        .checkbox-group {
            display:flex; flex-wrap:wrap; gap:8px; padding:4px 0;
        }
        .checkbox-group label {
            display:flex; align-items:center; gap:6px; background:#f8fafc;
            padding:4px 14px; border-radius:30px; border:1px solid #e2e8f0;
            cursor:pointer; font-size:13px; font-weight:500;
        }
        .checkbox-group label:hover { border-color:#2563eb; background:#eff6ff; }

        .live-timer {
            font-family:'Courier New',monospace; font-weight:700; color:#2563eb;
            background:#eff6ff; padding:2px 12px; border-radius:6px; font-size:13px;
            display:inline-block; min-width:70px; text-align:center;
        }
        .live-timer.overdue { color:#dc2626; background:#fee2e2; animation: blinkTimer 1s infinite; }
        @keyframes blinkTimer { 0%,100%{opacity:1;} 50%{opacity:0.5;} }

        .notif-container {
            position:fixed; top:20px; right:20px; z-index:9999;
            max-width:380px; width:100%; display:flex; flex-direction:column; gap:8px;
        }
        .notif {
            background:white; padding:14px 18px; border-radius:12px;
            box-shadow:0 6px 20px rgba(0,0,0,0.10); display:flex; align-items:center;
            gap:10px; animation:slideIn 0.25s ease; border-left:5px solid;
        }
        .notif.success { border-left-color:#22c55e; }
        .notif.danger { border-left-color:#ef4444; }
        .notif.warning { border-left-color:#f59e0b; }
        .notif.info { border-left-color:#3b82f6; }
        .notif .close { background:none; border:none; font-size:18px; cursor:pointer; color:#94a3b8; margin-left:auto; }
        .notif .close:hover { color:#ef4444; }
        @keyframes slideIn { from { transform:translateX(100%); opacity:0; } to { transform:translateX(0); opacity:1; } }

        @media (max-width:820px) { .sidebar { display:none; } .main { padding:16px; } }

        /* SweetAlert2 Custom */
.swal-custom-popup {
    border-radius: 20px !important;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15) !important;
}
.swal2-actions .btn {
    padding: 10px 28px !important;
    border-radius: 10px !important;
    font-weight: 600 !important;
    font-size: 14px !important;
}
.swal2-actions .btn-primary {
    background: #2563eb !important;
    color: white !important;
    border: none !important;
}
.swal2-actions .btn-primary:hover {
    background: #1d4ed8 !important;
}
.swal2-actions .btn-outline {
    background: transparent !important;
    border: 2px solid #e2e8f0 !important;
    color: #334155 !important;
}
.swal2-actions .btn-outline:hover {
    background: #f1f5f9 !important;
}
.swal2-validation-message {
    background: #fef2f2 !important;
    color: #dc2626 !important;
    border-radius: 8px !important;
    font-size: 13px !important;
}
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="brand"><i class="fas fa-bolt"></i> HelpDesk Pro</div>
        <div>
            <div class="menu-label">Menu</div>
            <div class="nav-item active" onclick="switchTab('tickets')"><i class="fas fa-ticket-alt"></i> Tiket</div>
            <div class="nav-item" onclick="switchTab('technicians')"><i class="fas fa-user-cog"></i> Teknisi</div>
        </div>
        <div style="margin-top:auto; border-top:1px solid #1e3557; padding-top:20px;">
            <div class="nav-item" style="color:#7b8ba3;"><i class="fas fa-circle" style="color:#22c55e;font-size:10px;"></i> Live</div>
        </div>
    </aside>

    <!-- MAIN -->
    <div class="main">

        <div class="top-bar">
            <h1>⚡ Dashboard</h1>
            <div class="live-badge"><span class="dot"></span> Realtime</div>
        </div>

        <!-- STATS -->
        <div class="stats-grid">
            <div class="stat-card">
                <div><div class="num" id="totalTickets">0</div><div class="label">Total Tiket</div></div>
                <div class="icon-circle blue"><i class="fas fa-tasks"></i></div>
                <button class="btn-stat" onclick="filterToday()">Hari ini</button>
            </div>
            <div class="stat-card">
                <div><div class="num" id="openTickets">0</div><div class="label">Open</div></div>
                <div class="icon-circle orange"><i class="fas fa-clock"></i></div>
                <button class="btn-stat" onclick="filterStatus('open')">Lihat</button>
            </div>
            <div class="stat-card">
                <div><div class="num" id="closedTickets">0</div><div class="label">Closed</div></div>
                <div class="icon-circle green"><i class="fas fa-check-circle"></i></div>
                <button class="btn-stat" onclick="filterStatus('close')">Lihat</button>
            </div>
            <div class="stat-card">
                <div><div class="num" id="pendingTickets">0</div><div class="label">Pending</div></div>
                <div class="icon-circle red"><i class="fas fa-pause-circle"></i></div>
                <button class="btn-stat" onclick="filterStatus('pending')">Lihat</button>
            </div>
        </div>

        <!-- TABEL TIKET (langsung tampil, tanpa tab) -->
        <div id="ticketSection">
            <div class="card">
                <div class="card-title"><i class="fas fa-plus-circle" style="color:#2563eb;"></i> Buat Tiket</div>
                <div class="form-grid">
                    <div class="form-group"><label>ID Ticket</label><input type="text" id="ticketId" placeholder="T-001"></div>
                    <div class="form-group"><label>Customer</label><input type="text" id="customer" placeholder="Nama Customer"></div>
                    <div class="form-group"><label>Deskripsi</label><textarea id="description" placeholder="Gangguan"></textarea></div>
                    <div class="form-group"><label>Durasi (menit)</label><input type="number" id="duration" value="60"></div>
                    <div class="form-group">
    <label>Pilih Teknisi <span style="font-weight:400;font-size:12px;color:#64748b;">(pilih lebih dari 1)</span></label>
    <div style="display:flex;gap:8px;align-items:center;">
        <select id="techSelect" style="flex:1;padding:8px 12px;border:1px solid #d1d9e6;border-radius:10px;font-size:14px;background:white;">
            <option value="">-- Pilih Teknisi --</option>
        </select>
        <button type="button" class="btn btn-primary" onclick="addTechToTicket()" style="padding:8px 16px;white-space:nowrap;">
            <i class="fas fa-plus"></i> Tambah
        </button>
    </div>
    <div id="selectedTechs" style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;padding:6px 0;min-height:32px;">
        <span style="color:#94a3b8;font-size:13px;">Belum ada teknisi dipilih</span>
    </div>
</div>
                    <div class="form-group" style="justify-content:flex-end;">
                        <button class="btn btn-primary" onclick="addTicket()"><i class="fas fa-paper-plane"></i> Buat</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-title"><i class="fas fa-table"></i> Daftar Tiket <span style="font-weight:400;color:#5b6e89;font-size:13px;" id="ticketCount">0 tiket</span></div>
                <div class="filter-bar">
                    <input type="date" id="filterDate" onchange="applyFilters()">
                    <input type="text" id="filterId" placeholder="ID Tiket" oninput="applyFilters()">
                    <input type="text" id="filterCustomer" placeholder="Customer" oninput="applyFilters()">
                    <select id="filterStatusSelect" onchange="applyFilters()">
                        <option value="all">Semua Status</option>
                        <option value="open">Open</option>
                        <option value="close">Close</option>
                        <option value="pending">Pending</option>
                    </select>
                    <button class="btn btn-outline btn-sm" onclick="resetFilters()"><i class="fas fa-undo"></i> Reset</button>
                </div>
                <div class="table-wrap">
                    <table>
                        <thead><tr>
                            <th>Tanggal</th><th>ID</th><th>Customer</th><th>Deskripsi</th>
                            <th>Durasi</th><th>Dibuat</th><th>Teknisi</th>
                            <th>Close Est</th><th>TTR</th><th>Status</th><th>Jenis Perbaikan</th><th>Aksi</th>
                        </tr></thead>
                        <tbody id="ticketBody"><tr><td colspan="11"><div class="empty"><span class="icon">📭</span>Belum ada tiket</div></td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- TEKNISI (tersembunyi, muncul via sidebar) -->
        <div id="technicianSection" style="display:none;">
            <div class="card">
                <div class="card-title"><i class="fas fa-user-plus"></i> Kelola Teknisi</div>
                <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:16px;">
                    <input type="text" id="techName" placeholder="Nama teknisi" style="flex:1;min-width:150px;padding:8px 12px;border:1px solid #d1d9e6;border-radius:10px;">
                    <input type="text" id="techPhone" placeholder="No HP (optional)" style="flex:1;min-width:150px;padding:8px 12px;border:1px solid #d1d9e6;border-radius:10px;">
                    <button class="btn btn-primary" id="btnTambahTeknisi"><i class="fas fa-plus"></i> Tambah</button>
                </div>
                <div class="table-wrap">
                    <table><thead><tr><th>No</th><th>Nama</th><th>HP</th><th>Aksi</th></tr></thead>
                        <tbody id="techTableBody"><tr><td colspan="4"><div class="empty"><span class="icon">👨‍🔧</span><p>Belum ada teknisi</p></div></td></tr></tbody>
                    </table>
                </div>
            </div>
            <div class="card">
                <div class="card-title"><i class="fas fa-chart-simple"></i> Performansi Teknisi</div>
                <div class="table-wrap">
                    <table><thead><tr><th>No</th><th>Nama</th><th>Total</th><th>Selesai</th><th>Proses</th><th>Overdue</th><th>Rata TTR</th></tr></thead>
                        <tbody id="perfBody"><tr><td colspan="7"><div class="empty"><span class="icon">📊</span><p>Belum ada data</p></div></td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    <!-- NOTIF -->
    <div class="notif-container" id="notifContainer"></div>

    <div id="editModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center;">
    <div style="background:white; border-radius:16px; padding:30px; max-width:400px; width:90%;">
        <h3 style="margin-bottom:16px;">Edit Teknisi</h3>
        <div style="margin-bottom:12px;">
            <label style="display:block; font-weight:600; margin-bottom:4px;">Nama</label>
            <input type="text" id="editTechName" style="width:100%; padding:8px 12px; border:1px solid #d1d9e6; border-radius:8px;">
        </div>
        <div style="margin-bottom:20px;">
            <label style="display:block; font-weight:600; margin-bottom:4px;">No HP</label>
            <input type="text" id="editTechPhone" style="width:100%; padding:8px 12px; border:1px solid #d1d9e6; border-radius:8px;">
        </div>
        <div style="display:flex; gap:10px; justify-content:flex-end;">
            <button class="btn btn-outline" onclick="closeEditModal()">Batal</button>
            <button class="btn btn-primary" id="saveEditBtn">Simpan</button>
        </div>
    </div>
</div>

    <!-- Firebase -->
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-firestore-compat.js"></script>

    <script>
        const firebaseConfig = {
            apiKey: "AIzaSyAfwYQ09GrxX2ln_kvMRY64dzgA5i-DLr0",
            authDomain: "management-gangguan.firebaseapp.com",
            projectId: "management-gangguan",
            storageBucket: "management-gangguan.firebasestorage.app",
            messagingSenderId: "195844922261",
            appId: "1:195844922261:web:0d51dba2518847da23349c"
        };
        firebase.initializeApp(firebaseConfig);
        const db = firebase.firestore();

        let techs = [];
        let tickets = [];
        let timerInterval = null;
        let timerRunning = false;
        let editingTechId = null;
        let selectedTechs = [];


        function notif(msg, type='info') {
            const c = document.getElementById('notifContainer');
            const el = document.createElement('div');
            el.className = `notif ${type}`;
            el.innerHTML = `<span>${msg}</span><button class="close" onclick="this.parentElement.remove()">×</button>`;
            c.appendChild(el);
            setTimeout(() => { if(el.parentElement) el.remove(); }, 5000);
        }

        // SWITCH TAB (SIDEBAR)
        function switchTab(tab) {
            document.querySelectorAll('.sidebar .nav-item').forEach(el => el.classList.remove('active'));
            if(tab==='tickets') {
                document.querySelector('.sidebar .nav-item:first-child').classList.add('active');
                document.getElementById('ticketSection').style.display = 'block';
                document.getElementById('technicianSection').style.display = 'none';
            } else {
                document.querySelector('.sidebar .nav-item:last-child').classList.add('active');
                document.getElementById('ticketSection').style.display = 'none';
                document.getElementById('technicianSection').style.display = 'block';
                renderPerformance();
            }
        }

        function openEditModal(id, name, phone) {
    editingTechId = id;
    document.getElementById('editTechName').value = name;
    document.getElementById('editTechPhone').value = phone;
    document.getElementById('editModal').style.display = 'flex';
}

function closeEditModal() {
    document.getElementById('editModal').style.display = 'none';
    editingTechId = null;
}

// ===== UBAH FUNGSI editTech =====
function editTech(id, name, phone) {
    openEditModal(id, name, phone);
}

// ===== TAMBAHKAN EVENT SAVE =====
document.getElementById('saveEditBtn').addEventListener('click', async function() {
    if(!editingTechId) return;
    const newName = document.getElementById('editTechName').value.trim();
    const newPhone = document.getElementById('editTechPhone').value.trim();
    
    if(!newName) { notif('Nama tidak boleh kosong!','warning'); return; }
    
    try {
        await db.collection('technicians').doc(editingTechId).update({
            name: newName,
            phone: newPhone || '-'
        });
        notif('Teknisi berhasil diupdate!','success');
        closeEditModal();
    } catch(e) {
        notif('Gagal update teknisi','danger');
    }
});

        function renderTechDropdown() {
    const select = document.getElementById('techSelect');
    if(!select) return;
    select.innerHTML = '<option value="">-- Pilih --</option>';
    techs.forEach(t => {
        if(!selectedTechs.includes(t.name)) {
            const opt = document.createElement('option');
            opt.value = t.name;
            opt.textContent = t.name;
            select.appendChild(opt);
        }
    });
    renderSelectedTechs();
}

function renderSelectedTechs() {
    const container = document.getElementById('selectedTechs');
    if(!container) return;
    if(selectedTechs.length === 0) {
        container.innerHTML = '<span style="color:#94a3b8;font-size:13px;">Belum ada teknisi</span>';
        return;
    }
    container.innerHTML = selectedTechs.map(name => `
        <span style="background:#eef2ff;padding:4px 14px;border-radius:20px;font-size:13px;border:1px solid #c7d2fe;display:inline-flex;align-items:center;gap:8px;">
            ${name}
            <span onclick="removeTechFromTicket('${name}')" style="cursor:pointer;color:#dc2626;font-weight:700;">×</span>
        </span>
